[Unit]
Description=PINGUI dev session (venv, in-memory route monitor)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/path/to/PINGUI
ExecStart=/path/to/PINGUI/pingui.sh
# Опційно time-series:
# Environment=PINGUI_TIMESCALE_DSN=postgresql://user:pass@localhost/pingui
# ExecStart=/path/to/PINGUI/pingui.sh --ts-backend timescale
# Розгортання: /path/to/PINGUI/pingui.sh --deploy
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
